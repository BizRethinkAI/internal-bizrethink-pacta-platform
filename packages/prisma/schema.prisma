// DO NOT EDIT BY HAND. Edit packages/bizrethink/prisma-extensions/additions.prisma
// then run: npm run prisma:merge-additions (or trigger any prisma script in this package).

// BizRethink-specific Prisma model additions.
//
// This file is the SINGLE SOURCE OF TRUTH for all custom DB tables added by
// BizRethink on top of Documenso's upstream schema. It is NEVER concatenated
// directly into Prisma's schema by hand — instead, `merge-into-schema.mjs`
// reads this file and appends its contents into `packages/prisma/schema.prisma`
// between marker comments at build time. Running `merge-into-schema.mjs` is
// idempotent: it strips any existing marker block before re-appending.
//
// Wired in via overlay 007 — `packages/prisma/package.json` calls this merge
// script before every `prisma generate`.
//
// Conventions:
//   - All model names are prefixed with `Bizrethink` to avoid collision with
//     any upstream model Documenso may add later.
//   - Encrypted columns use `String` type (not bytes) because we encrypt with
//     `NEXT_PRIVATE_ENCRYPTION_KEY` and store the result as base64.
//   - Foreign-key relations to upstream models (Organisation, User) use
//     plain `String` columns WITHOUT a Prisma `@relation` directive. Prisma
//     requires both ends of a relation to be declared in the same schema,
//     and adding the reverse-relation field to upstream's `Organisation`
//     model would mean modifying upstream code. Trade-off: no automatic
//     cascade behaviour (we handle that manually in code where needed),
//     no Prisma client `.organisation` accessor on these models. Worth it
//     to keep the discipline of "upstream files untouched."

// ─── Phase B (overlay 010) — per-org SMTP credentials ─────────────────────
//
// One row per organisation, holding the SMTP credentials that organisation's
// outgoing mail authenticates with. Replaces the global `NEXT_PRIVATE_SMTP_*`
// env vars at the per-org level. Falls back to env-default when no row exists.

model BizrethinkOrganisationSmtpConfig {
  id             String @id
  organisationId String @unique

  // Mirrors `NEXT_PRIVATE_SMTP_TRANSPORT`. Phase B v1 supports `smtp-auth` only;
  // future expansion: `smtp-api`, `mailchannels`, `resend` (each adds its own
  // credential fields, possibly via separate columns or a typed JSON blob).
  transport String @default("smtp-auth")

  // SMTP-AUTH connection settings (mirrors `NEXT_PRIVATE_SMTP_HOST/PORT/SECURE`).
  host   String
  port   Int     @default(587)
  secure Boolean @default(false)

  // Auth credentials. `password` is ENCRYPTED AT REST with
  // `NEXT_PRIVATE_ENCRYPTION_KEY` via `symmetricEncrypt`. Decrypt at send time.
  username String
  password String

  // Sender identity (mirrors `NEXT_PRIVATE_SMTP_FROM_NAME/FROM_ADDRESS`). The
  // `fromAddress` should be on a verified EmailDomain for the same org —
  // we don't enforce that constraint here in Prisma but the admin UI surfaces
  // a warning if it's not.
  fromName    String
  fromAddress String

  // Last "Test connection" attempt — used by the admin UI to show status
  // without re-running the test on every page load.
  lastTestedAt  DateTime?
  lastTestError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Phase C (overlay 011) — instance signing config ──────────────────────
//
// Singleton row holding the cryptographic-signing configuration for the
// whole instance. Replaces the env-driven cert/passphrase/TSA workflow
// (`NEXT_PRIVATE_SIGNING_*` env vars) with an admin UI. Exactly one row,
// always identified by `id = "singleton"`.
//
// Falls back to env reads if no row exists, so the env-driven path remains
// the bootstrap default. After the admin saves a row via `/admin/signing`,
// the DB row takes precedence and the in-memory caches in
// `packages/signing/index.ts:getSigner()` and `packages/signing/helpers/tsa.ts`
// are invalidated.

model BizrethinkInstanceSigningConfig {
  id String @id @default("singleton")

  // `local` (P12 cert + passphrase) or `gcloud-hsm`. Mirrors
  // `NEXT_PRIVATE_SIGNING_TRANSPORT`. Only one row exists, so changing
  // transport replaces the entire signing setup.
  transport String @default("local")

  // ── local-cert fields ──
  // Base64-encoded P12 contents, ENCRYPTED AT REST with
  // `NEXT_PRIVATE_ENCRYPTION_KEY` via `symmetricEncrypt`. Decrypted on
  // load and decoded from base64 to get the raw cert bytes.
  localCertContents String?
  localPassphrase   String?

  // ── gcloud-hsm fields ──
  // GCP KMS key version path. Plain text — not sensitive.
  gcloudKeyPath     String?
  // Base64-encoded service-account JSON, ENCRYPTED AT REST.
  gcloudCredentials String?
  // Base64-encoded PEM cert chain, ENCRYPTED AT REST.
  gcloudCertChain   String?

  // Comma-separated TSA URLs (mirrors `NEXT_PRIVATE_SIGNING_TIMESTAMP_AUTHORITY`).
  // Empty = no timestamping. With at least one URL, LTV + archival timestamp
  // are also enabled.
  tsaUrls String?

  // Embedded in every signed PDF as Contact Info field. Mirrors
  // `NEXT_PUBLIC_SIGNING_CONTACT_INFO`. Defaults to webapp URL if null.
  signingContactInfo String?

  updatedAt       DateTime @updatedAt
  updatedByUserId Int?
}

// ─── Phase E (overlay 013) — instance storage config ──────────────────────
//
// Singleton row holding the file-storage configuration: transport
// (database vs s3) plus all S3 connection details when transport=s3.
// Replaces five NEXT_PRIVATE_UPLOAD_* env vars + NEXT_PUBLIC_UPLOAD_TRANSPORT.
//
// Falls back to env reads when the row is absent. After the admin saves a
// row via /admin/storage, the in-memory S3Client cache is busted so the
// next file write/read hits the new transport.
//
// Migration of existing PDFs from db→s3 is OUT OF SCOPE here — that's a
// separate one-shot script. This UI just toggles the transport for new
// uploads.

model BizrethinkInstanceStorageConfig {
  id String @id @default("singleton")

  // 'database' (Postgres bytea) or 's3' (any S3-compatible endpoint).
  transport String @default("database")

  // S3 connection settings. Each is null when transport='database'.
  s3Endpoint       String?
  s3ForcePathStyle Boolean @default(false)
  s3Region         String?
  s3Bucket         String?

  // Encrypted at rest with NEXT_PRIVATE_ENCRYPTION_KEY.
  s3AccessKeyId     String?
  s3SecretAccessKey String?

  // Optional CDN distribution (CloudFront-style signed URLs).
  s3DistributionDomain String?
  s3DistributionKeyId  String?
  s3DistributionKeyPem String?

  updatedAt       DateTime @updatedAt
  updatedByUserId Int?
}

// ─── Phase F (overlay 014) — SSO provider config ──────────────────────────
//
// One row per provider (google / microsoft / oidc). Replaces the 9
// NEXT_PRIVATE_GOOGLE_*/MICROSOFT_*/OIDC_* env vars. Per-provider
// `enabled` toggles whether the provider is wired in at runtime.
//
// Falls back to env reads when no row exists for a provider.

model BizrethinkSsoProvider {
  // 'google' | 'microsoft' | 'oidc'.
  provider String @id

  enabled Boolean @default(false)

  // Encrypted at rest with NEXT_PRIVATE_ENCRYPTION_KEY.
  clientId     String?
  clientSecret String?

  // OIDC-only. wellKnownUrl + label + skipVerify + prompt.
  oidcWellKnownUrl  String?
  oidcProviderLabel String?
  oidcSkipVerify    Boolean @default(false)
  // 'none' | 'login' | 'consent' | 'select_account'. Empty = use provider default.
  oidcPrompt        String?

  updatedAt       DateTime @updatedAt
  updatedByUserId Int?
}

// ─── Phase H (overlay 016) — Google Vertex AI config ──────────────────────
//
// Singleton row holding Google Vertex AI credentials. Replaces three env vars:
// GOOGLE_VERTEX_PROJECT_ID / _LOCATION / _API_KEY. Used by AI-assisted
// contract review (when wired upstream). aiFeaturesEnabled per-org/team is
// upstream-managed; this row provides the instance-wide credentials AI
// consumers will need.

model BizrethinkInstanceAiConfig {
  id String @id @default("singleton")

  enabled Boolean @default(false)

  // Plain text — project IDs are not sensitive.
  vertexProjectId String?
  vertexLocation  String?

  // Encrypted at rest with NEXT_PRIVATE_ENCRYPTION_KEY.
  vertexApiKey String?

  updatedAt       DateTime @updatedAt
  updatedByUserId Int?
}

// ─── Phase J (overlay 041) — per-org billing metadata ─────────────────────
//
// One row per organisation, holding BizRethink-specific fields layered on
// top of upstream's billing primitives. Upstream already provides:
//   - `Organisation.customerId` (Stripe customer ID)
//   - `Subscription` model with status / planId / priceId / periodEnd
//   - `OrganisationClaim` with tier flags + caps
//
// This model fills two gaps upstream doesn't cover:
//   1. `bizrethinkInternal` — marks BizRethink-operated orgs (Personal,
//       BizRethink AI, MFG, MORG CAP) that should always retain the
//       BIZRETHINK claim regardless of Stripe subscription state. New
//       external customers default to `false` and follow normal
//       Free/Trial/Paid tier flow.
//   2. Trial bookkeeping — `trialStartedAt` / `trialEndsAt` track the
//      14-day Pro evaluation that new external orgs get on signup.
//      Cleared when a Stripe subscription becomes active; preserved as
//      audit trail otherwise. The trial-expire-sweep Inngest job
//      (overlay 044) consults these fields to downgrade expired trials.
//
// Row creation: overlay 041 inserts a row at org-creation time. Default
// values mean missing rows behave as "external, no trial set" — safe
// fallback if the row is somehow absent.

model BizrethinkOrganisationBilling {
  id             String @id @default(cuid())
  organisationId String @unique

  // True ONLY for BizRethink-operated orgs. Set manually by admin or via
  // bootstrap migration for the 4 current production orgs. Drives the
  // BIZRETHINK-vs-FREE_TRIAL routing decision at org-creation time in
  // packages/lib/server-only/organisation/create-organisation.ts (overlay 041).
  bizrethinkInternal Boolean @default(false)

  // 14-day Pro trial window. Set at org creation (when bizrethinkInternal
  // is false). `trialEndsAt` is the cron job's selector: orgs with
  // trialEndsAt < now() AND no active Subscription get downgraded to FREE.
  // After downgrade these fields remain populated for audit; the cron's
  // selector also checks the org's current OrganisationClaim to avoid
  // re-downgrading.
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

