# Why: Originally added an inline "Signed YYYY-MM-DD HH:MM UTC" badge
#      below each signature image (Dotloop pattern). On 2026-05-09 the
#      badge was found to overlap the signature glyph at our standard
#      widget height (20pt) — badge y was field.height-9, which placed
#      it at y=11..20 inside a 20pt rect, colliding with the bottom half
#      of the signature image. User pushback: "the signed date/time
#      stamp overlaps the signature, needs to be removed or fixed."
#
#      Decision: remove the inline badge entirely. The per-page footer
#      stamp (overlay 036) already carries visible execution metadata,
#      and Documenso's audit-log page at the end provides the
#      authoritative timestamps. The inline badge was redundant and
#      visually noisy.
#
#      What this patch keeps: the FieldToRender.signature Pick<> still
#      includes `created?: Date | null` in BOTH duplicate type
#      definitions (field-renderer.ts + render-field.ts). The field is
#      optional so nothing currently in the codebase requires it, but
#      keeping it preserves the option to re-introduce a non-overlapping
#      stamp later (e.g. positioned in adjacent whitespace) without
#      re-touching consumer types.
#
# Why-not-additive: the FieldToRender Pick<> is upstream and there's no
#      cleaner way to thread an extra signature field through to the
#      renderer without amending it.
#
# Upstream-merge-fragility: LOW
#      Only adds an optional field to two duplicate Pick<> types. No
#      runtime-behavior changes against upstream after this revision.
#
# Files patched:
#   - packages/lib/universal/field-renderer/field-renderer.ts
#   - packages/lib/universal/field-renderer/render-field.ts

diff --git a/packages/lib/universal/field-renderer/field-renderer.ts b/packages/lib/universal/field-renderer/field-renderer.ts
index 8f66084e2..7b9bbe733 100644
--- a/packages/lib/universal/field-renderer/field-renderer.ts
+++ b/packages/lib/universal/field-renderer/field-renderer.ts
@@ -19,7 +19,16 @@ export type FieldToRender = Pick<
   positionX: number;
   positionY: number;
   fieldMeta?: TFieldMetaSchema | null;
-  signature?: Pick<Signature, 'signatureImageAsBase64' | 'typedSignature'> | null;
+  // BizRethink overlay 037: keep `created` reachable through the renderer's
+  // signature Pick<> so a future inline-stamp implementation can re-use
+  // it without re-touching consumer types. The original inline badge was
+  // removed (overlapped signatures at our standard 20pt height); the
+  // per-page footer (overlay 036) carries execution metadata. `created`
+  // is optional so client-side callers (e.g. `EnvelopeRenderFieldSignature`)
+  // can construct minimal signature objects without the timestamp.
+  signature?:
+    | (Pick<Signature, 'signatureImageAsBase64' | 'typedSignature'> & { created?: Date | null })
+    | null;
 };

 export type RenderFieldElementOptions = {
diff --git a/packages/lib/universal/field-renderer/render-field.ts b/packages/lib/universal/field-renderer/render-field.ts
index d7000389a..0b8a6df7e 100644
--- a/packages/lib/universal/field-renderer/render-field.ts
+++ b/packages/lib/universal/field-renderer/render-field.ts
@@ -36,7 +36,15 @@ export type FieldToRender = Pick<
   positionX: number;
   positionY: number;
   fieldMeta?: TFieldMetaSchema | null;
-  signature?: Pick<Signature, 'signatureImageAsBase64' | 'typedSignature'> | null;
+  // BizRethink overlay 037: kept in sync with the duplicate FieldToRender
+  // in `field-renderer.ts`. `created` reachable through the Pick<> in
+  // case a non-overlapping inline stamp is added later. The original
+  // inline badge was removed for overlapping signature images. Optional
+  // so client-side callers can construct minimal signature objects
+  // without the timestamp.
+  signature?:
+    | (Pick<Signature, 'signatureImageAsBase64' | 'typedSignature'> & { created?: Date | null })
+    | null;
 };

